{
  "name": "tyndale-next",
  "version": "1.1.0",
  "description": "Next.js adapter for Tyndale i18n",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ogrodev/tyndale.git",
    "directory": "packages/tyndale-next"
  },
  "homepage": "https://github.com/ogrodev/tyndale",
  "bugs": {
    "url": "https://github.com/ogrodev/tyndale/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "import": "./dist/middleware.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "bun test"
  },
  "keywords": [
    "i18n",
    "internationalization",
    "nextjs",
    "next",
    "translation",
    "ai",
    "middleware"
  ],
  "dependencies": {
    "tyndale-react": "workspace:*"
  },
  "peerDependencies": {
    "next": ">=14.0.0",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "next": "^16.2.4",
    "typescript": "^6.0.3"
  }
}
