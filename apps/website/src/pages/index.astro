---
import Landing from '../layouts/Landing.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';
import { createT } from '../lib/translations';
import { strings } from '../lib/strings';

const t = createT('en');
---

<Landing locale="en">
  <Header locale="en" t={t} strings={strings} />
  <main id="main-content">

    <!-- ═══ HERO — Compact Terminal Header ═══ -->
    <section class="hero-glow pt-28 pb-16 px-6">
      <div class="max-w-4xl mx-auto animate-fade-up stagger-1">
        <!-- Terminal window -->
        <div class="bg-[#131313] border border-white/6 rounded-2xl overflow-hidden">
          <!-- Terminal title bar -->
          <div class="flex items-center gap-2 px-4 py-3 border-b border-white/6">
            <span class="w-3 h-3 rounded-full bg-[#ff5f57]/50"></span>
            <span class="w-3 h-3 rounded-full bg-[#febc2e]/50"></span>
            <span class="w-3 h-3 rounded-full bg-[#28c840]/50"></span>
            <span class="ml-3 text-xs font-mono text-[#6b6b67]">tyndale</span>
          </div>
          <!-- Terminal body -->
          <div class="p-6 md:p-8">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-accent-400 font-mono text-sm">$</span>
              <span class="font-mono text-sm text-[#6b6b67]">cat hero.tsx</span>
            </div>
            <p class="font-mono text-2xl md:text-3xl text-[#e5e5e3] leading-tight terminal-type">
              {t(strings.heroTitle)}
            </p>
          </div>
        </div>

        <!-- Accent title below terminal -->
        <h1 class="text-accent-400 text-4xl md:text-5xl font-bold tracking-tight text-center mt-8">
          {t(strings.heroTitleAccent)}
        </h1>

        <!-- Subtitle -->
        <p class="text-center text-[#9b9b97] text-sm md:text-base max-w-xl mx-auto mt-4">
          {t(strings.heroSubtitle)}
        </p>

        <!-- CTAs -->
        <div class="flex items-center justify-center gap-3 mt-6">
          <a href="/getting-started/installation" class="inline-flex items-center gap-2 px-5 py-2.5 bg-accent-500 hover:bg-accent-600 text-white text-sm font-medium rounded-lg transition-colors">
            {t(strings.ctaGetStarted)}
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="https://github.com/ogrodev/tyndale" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-5 py-2.5 bg-white/5 hover:bg-white/10 text-[#c4c4c0] text-sm font-medium rounded-lg border border-white/6 transition-colors">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            {t(strings.ctaGitHub)}
          </a>
        </div>
      </div>
    </section>

    <!-- ═══ FEATURES — Bento Grid ═══ -->
    <section class="py-16 px-6">
      <div class="max-w-6xl mx-auto">
        <!-- Section header -->
        <div class="mb-8 animate-fade-up stagger-1">
          <p class="text-sm font-mono text-accent-400 mb-2 tracking-wider uppercase">{t(strings.featuresTitle)}</p>
          <p class="text-base text-[#6b6b67] max-w-lg">{t(strings.featuresSubtitle)}</p>
        </div>

        <!-- Bento grid -->
        <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-3">

          <!-- Zero-key (LARGE) — col-span-2 md:col-span-4 row-span-2 -->
          <article class="feature-card bg-[#131313] rounded-xl p-6 col-span-2 md:col-span-4 row-span-2 animate-fade-up stagger-1">
            <div class="flex items-start gap-3 mb-4">
              <div class="flex items-center justify-center w-8 h-8 rounded-md bg-accent-500/10 shrink-0">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 4l6-2 6 2v6l-6 2-6-2V4z" stroke="currentColor" stroke-width="1.5" class="text-accent-400"/><path d="M2 4l6 2 6-2" stroke="currentColor" stroke-width="1.5" class="text-accent-400"/><path d="M8 6v8" stroke="currentColor" stroke-width="1.5" class="text-accent-400"/></svg>
              </div>
              <div>
                <h3 class="text-xl font-semibold text-[#e5e5e3] tracking-tight">{t(strings.featureZeroKeyTitle)}</h3>
                <p class="text-sm text-[#6b6b67] mt-1">{t(strings.featureZeroKeyDesc)}</p>
              </div>
            </div>
            <!-- Embedded code preview -->
            <div class="bg-[#0a0a0b] rounded-lg border border-white/4 overflow-hidden">
              <div class="flex items-center gap-1.5 px-3 py-2 border-b border-white/4">
                <span class="w-2 h-2 rounded-full bg-[#ff5f57]/40"></span>
                <span class="w-2 h-2 rounded-full bg-[#febc2e]/40"></span>
                <span class="w-2 h-2 rounded-full bg-[#28c840]/40"></span>
                <span class="ml-2 text-[10px] font-mono text-[#6b6b67]">Welcome.tsx</span>
              </div>
              <pre class="p-4 text-sm font-mono leading-relaxed overflow-x-auto"><code><span class="text-accent-400">import</span> <span class="text-[#c4c4c0]">{'{'} T, useTranslation {'}'}</span> <span class="text-accent-400">from</span> <span class="text-[#9b9b97]">'tyndale-react'</span>;

<span class="text-accent-400">export function</span> <span class="text-[#e5e5e3]">Welcome</span><span class="text-[#6b6b67]">()</span> <span class="text-[#6b6b67]">{'{'}</span>
  <span class="text-accent-400">const</span> <span class="text-[#c4c4c0]">t</span> = <span class="text-[#e5e5e3]">useTranslation</span><span class="text-[#6b6b67]">()</span>;
  <span class="text-accent-400">return</span> <span class="text-[#6b6b67]">(</span>
    <span class="text-[#6b6b67]">&lt;</span><span class="text-accent-300">div</span><span class="text-[#6b6b67]">&gt;</span>
      <span class="text-[#6b6b67]">&lt;</span><span class="text-accent-300">T</span><span class="text-[#6b6b67]">&gt;</span><span class="text-[#c4c4c0]">Welcome to our app!</span><span class="text-[#6b6b67]">&lt;/</span><span class="text-accent-300">T</span><span class="text-[#6b6b67]">&gt;</span>
      <span class="text-[#6b6b67]">&lt;</span><span class="text-accent-300">p</span><span class="text-[#6b6b67]">&gt;{'{'}</span><span class="text-[#c4c4c0]">t</span><span class="text-[#6b6b67]">(</span><span class="text-[#9b9b97]">'You have 3 new messages'</span><span class="text-[#6b6b67]">){'}'}&lt;/</span><span class="text-accent-300">p</span><span class="text-[#6b6b67]">&gt;</span>
    <span class="text-[#6b6b67]">&lt;/</span><span class="text-accent-300">div</span><span class="text-[#6b6b67]">&gt;</span>
  <span class="text-[#6b6b67]">)</span>;
<span class="text-[#6b6b67]">{'}'}</span></code></pre>
            </div>
          </article>

          <!-- AI-powered — col-span-2 -->
          <article class="feature-card bg-[#131313] rounded-xl p-5 col-span-2 animate-fade-up stagger-2">
            <div class="flex items-center justify-center w-8 h-8 rounded-md bg-accent-500/10 mb-3">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 1l1.5 3.5L13 6l-3.5 1.5L8 11 6.5 7.5 3 6l3.5-1.5L8 1z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round" class="text-accent-400"/><path d="M12 10l.75 1.75L14.5 12.5l-1.75.75L12 15l-.75-1.75-1.75-.75 1.75-.75L12 10z" stroke="currentColor" stroke-width="1" stroke-linejoin="round" class="text-accent-400"/></svg>
            </div>
            <h3 class="text-base font-semibold text-[#e5e5e3]">{t(strings.featureAiTitle)}</h3>
            <p class="text-sm text-[#6b6b67] mt-1">{t(strings.featureAiDesc)}</p>
          </article>

          <!-- Incremental — col-span-2 -->
          <article class="feature-card bg-[#131313] rounded-xl p-5 col-span-2 animate-fade-up stagger-3">
            <div class="flex items-center justify-center w-8 h-8 rounded-md bg-accent-500/10 mb-3">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 5h10M3 8h6M3 11h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" class="text-accent-400"/></svg>
            </div>
            <h3 class="text-base font-semibold text-[#e5e5e3]">{t(strings.featureIncrementalTitle)}</h3>
            <p class="text-sm text-[#6b6b67] mt-1">{t(strings.featureIncrementalDesc)}</p>
            <!-- Mini diff display -->
            <div class="mt-3 text-xs font-mono space-y-0.5">
              <div class="text-[#6b6b67]"><span class="text-[#6b6b67]/60">  </span>unchanged line</div>
              <div class="text-red-400/70"><span class="text-red-400/50">- </span>old translation</div>
              <div class="text-green-400/70"><span class="text-green-400/50">+ </span>new translation</div>
            </div>
          </article>

          <!-- Rich content — col-span-2 -->
          <article class="feature-card bg-[#131313] rounded-xl p-5 col-span-2 animate-fade-up stagger-4">
            <div class="flex items-center justify-center w-8 h-8 rounded-md bg-accent-500/10 mb-3">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 3h12v10H2V3z" stroke="currentColor" stroke-width="1.5" class="text-accent-400"/><path d="M5 6h6M5 8h4M5 10h5" stroke="currentColor" stroke-width="1" stroke-linecap="round" class="text-accent-400"/></svg>
            </div>
            <h3 class="text-base font-semibold text-[#e5e5e3]">{t(strings.featureRichTitle)}</h3>
            <p class="text-sm text-[#6b6b67] mt-1">{t(strings.featureRichDesc)}</p>
            <!-- Plural example -->
            <div class="mt-3 bg-[#0a0a0b] rounded px-2 py-1.5 text-xs font-mono">
              <span class="text-accent-300">{'{'}</span><span class="text-[#c4c4c0]">count, plural,</span>
              <span class="text-accent-300"> one</span><span class="text-[#6b6b67]">{'{# item}'}</span>
              <span class="text-accent-300"> other</span><span class="text-[#6b6b67]">{'{# items}'}</span><span class="text-accent-300">{'}'}</span>
            </div>
          </article>

          <!-- Next.js — col-span-2 -->
          <article class="feature-card bg-[#131313] rounded-xl p-5 col-span-2 animate-fade-up stagger-5">
            <div class="flex items-center justify-center w-8 h-8 rounded-md bg-accent-500/10 mb-3">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 14L12.5 2M12.5 2H6M12.5 2v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-accent-400"/></svg>
            </div>
            <h3 class="text-base font-semibold text-[#e5e5e3]">{t(strings.featureNextTitle)}</h3>
            <p class="text-sm text-[#6b6b67] mt-1">{t(strings.featureNextDesc)}</p>
            <ul class="mt-2 space-y-1">
              <li class="text-xs font-mono text-[#9b9b97] flex items-center gap-1.5">
                <span class="w-1 h-1 rounded-full bg-accent-400/60"></span>Middleware
              </li>
              <li class="text-xs font-mono text-[#9b9b97] flex items-center gap-1.5">
                <span class="w-1 h-1 rounded-full bg-accent-400/60"></span>Server Components
              </li>
              <li class="text-xs font-mono text-[#9b9b97] flex items-center gap-1.5">
                <span class="w-1 h-1 rounded-full bg-accent-400/60"></span>Static Generation
              </li>
            </ul>
          </article>

          <!-- CI-friendly — col-span-2 -->
          <article class="feature-card bg-[#131313] rounded-xl p-5 col-span-2 animate-fade-up stagger-6">
            <div class="flex items-center justify-center w-8 h-8 rounded-md bg-accent-500/10 mb-3">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="2" y="3" width="12" height="10" rx="1.5" stroke="currentColor" stroke-width="1.5" class="text-accent-400"/><path d="M5 7l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-accent-400"/></svg>
            </div>
            <h3 class="text-base font-semibold text-[#e5e5e3]">{t(strings.featureCiTitle)}</h3>
            <p class="text-sm text-[#6b6b67] mt-1">{t(strings.featureCiDesc)}</p>
            <!-- Terminal output preview -->
            <div class="mt-3 bg-[#0a0a0b] rounded px-2 py-1.5 text-xs font-mono space-y-0.5">
              <div class="text-[#6b6b67]">$ npx tyndale validate</div>
              <div class="text-green-400/70">  es.json  42/42 keys</div>
              <div class="text-green-400/70">  fr.json  42/42 keys</div>
              <div class="text-green-400/70">  All translations valid</div>
            </div>
          </article>

        </div>
      </div>
    </section>

    <!-- ═══ CODE PIPELINE — Horizontal 3-Step Flow ═══ -->
    <section class="py-16 px-6">
      <div class="max-w-6xl mx-auto">
        <div class="mb-8 animate-fade-up">
          <p class="text-xs font-mono text-accent-400 mb-2 tracking-wider uppercase">{t(strings.codeDemoTitle)}</p>
          <p class="text-sm text-[#6b6b67]">{t(strings.codeDemoSubtitle)}</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-3 relative animate-fade-up stagger-2">
          <!-- Arrow connectors (desktop only) -->
          <div class="hidden md:flex absolute top-1/2 left-1/3 -translate-x-1/2 -translate-y-1/2 z-10">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M14 7l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent-400/50"/></svg>
          </div>
          <div class="hidden md:flex absolute top-1/2 left-2/3 -translate-x-1/2 -translate-y-1/2 z-10">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M14 7l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent-400/50"/></svg>
          </div>

          <!-- Step 1: Write component -->
          <div class="bg-[#131313] border border-white/6 rounded-xl overflow-hidden">
            <div class="flex items-center gap-2 px-3 py-2 border-b border-white/6">
              <span class="flex items-center justify-center w-5 h-5 rounded-full bg-accent-500 text-white text-xs font-mono font-bold">1</span>
              <span class="text-xs font-mono text-[#6b6b67]">{t(strings.codeDemoStep1)}</span>
            </div>
            <pre class="p-3 text-xs font-mono leading-relaxed overflow-x-auto"><code><span class="text-accent-400">import</span> <span class="text-[#c4c4c0]">{'{'} T {'}'}</span> <span class="text-accent-400">from</span> <span class="text-[#9b9b97]">'tyndale-react'</span>;

<span class="text-[#6b6b67]">&lt;</span><span class="text-accent-300">T</span><span class="text-[#6b6b67]">&gt;</span><span class="text-[#c4c4c0]">Welcome!</span><span class="text-[#6b6b67]">&lt;/</span><span class="text-accent-300">T</span><span class="text-[#6b6b67]">&gt;</span></code></pre>
          </div>

          <!-- Step 2: Run CLI -->
          <div class="bg-[#131313] border border-white/6 rounded-xl overflow-hidden">
            <div class="flex items-center gap-2 px-3 py-2 border-b border-white/6">
              <span class="flex items-center justify-center w-5 h-5 rounded-full bg-accent-500 text-white text-xs font-mono font-bold">2</span>
              <span class="text-xs font-mono text-[#6b6b67]">{t(strings.codeDemoStep2)}</span>
            </div>
            <pre class="p-3 text-xs font-mono leading-relaxed overflow-x-auto"><code><span class="text-[#6b6b67]">$</span> <span class="text-[#c4c4c0]">npx tyndale extract</span>
<span class="text-[#6b6b67]">$</span> <span class="text-[#c4c4c0]">npx tyndale translate</span>
<span class="text-green-400/70">  Translating to es, fr, de...</span>
<span class="text-green-400/70">  Done.</span></code></pre>
          </div>

          <!-- Step 3: Result -->
          <div class="bg-[#131313] border border-white/6 rounded-xl overflow-hidden">
            <div class="flex items-center gap-2 px-3 py-2 border-b border-white/6">
              <span class="flex items-center justify-center w-5 h-5 rounded-full bg-accent-500 text-white text-xs font-mono font-bold">3</span>
              <span class="text-xs font-mono text-[#6b6b67]">{t(strings.codeDemoStep3)}</span>
            </div>
            <pre class="p-3 text-xs font-mono leading-relaxed overflow-x-auto"><code><span class="text-[#6b6b67]">// es.json</span>
<span class="text-[#6b6b67]">{'{'}</span>
  <span class="text-accent-300">"Welcome!"</span><span class="text-[#6b6b67]">:</span>
    <span class="text-[#9b9b97]">"Bienvenido!"</span>
<span class="text-[#6b6b67]">{'}'}</span></code></pre>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ QUICK START — Horizontal Pipeline ═══ -->
    <section class="py-16 px-6">
      <div class="max-w-6xl mx-auto">
        <div class="mb-8 animate-fade-up">
          <p class="text-xs font-mono text-accent-400 mb-2 tracking-wider uppercase">{t(strings.quickStartTitle)}</p>
          <p class="text-sm text-[#6b6b67]">{t(strings.quickStartSubtitle)}</p>
        </div>

        <!-- Desktop: horizontal pipeline -->
        <div class="hidden md:flex items-start justify-between relative animate-fade-up stagger-2">
          <!-- Connecting line -->
          <div class="absolute top-4 left-[10%] right-[10%] h-px bg-white/6"></div>

          <!-- Step nodes -->
          <div class="pipeline-node flex flex-col items-center text-center w-1/5 relative z-10">
            <div class="w-8 h-8 rounded-full bg-accent-500 flex items-center justify-center text-xs font-mono font-bold text-white mb-3">1</div>
            <span class="text-xs font-semibold text-[#c4c4c0] mb-2">{t(strings.quickStartInstall)}</span>
            <code class="text-[10px] font-mono text-accent-300 bg-[#131313] px-2 py-1 rounded border border-white/6">bun add tyndale</code>
          </div>

          <div class="pipeline-node flex flex-col items-center text-center w-1/5 relative z-10">
            <div class="w-8 h-8 rounded-full bg-accent-500 flex items-center justify-center text-xs font-mono font-bold text-white mb-3">2</div>
            <span class="text-xs font-semibold text-[#c4c4c0] mb-2">{t(strings.quickStartInit)}</span>
            <code class="text-[10px] font-mono text-accent-300 bg-[#131313] px-2 py-1 rounded border border-white/6">npx tyndale init</code>
          </div>

          <div class="pipeline-node flex flex-col items-center text-center w-1/5 relative z-10">
            <div class="w-8 h-8 rounded-full bg-accent-500 flex items-center justify-center text-xs font-mono font-bold text-white mb-3">3</div>
            <span class="text-xs font-semibold text-[#c4c4c0] mb-2">{t(strings.quickStartWrap)}</span>
            <code class="text-[10px] font-mono text-accent-300 bg-[#131313] px-2 py-1 rounded border border-white/6">&lt;T&gt;text&lt;/T&gt;</code>
          </div>

          <div class="pipeline-node flex flex-col items-center text-center w-1/5 relative z-10">
            <div class="w-8 h-8 rounded-full bg-accent-500 flex items-center justify-center text-xs font-mono font-bold text-white mb-3">4</div>
            <span class="text-xs font-semibold text-[#c4c4c0] mb-2">{t(strings.quickStartTranslate)}</span>
            <code class="text-[10px] font-mono text-accent-300 bg-[#131313] px-2 py-1 rounded border border-white/6">npx tyndale translate</code>
          </div>

          <div class="pipeline-node flex flex-col items-center text-center w-1/5 relative z-10">
            <div class="w-8 h-8 rounded-full bg-accent-500 flex items-center justify-center text-xs font-mono font-bold text-white mb-3">5</div>
            <span class="text-xs font-semibold text-[#c4c4c0] mb-2">{t(strings.quickStartShip)}</span>
            <code class="text-[10px] font-mono text-accent-300 bg-[#131313] px-2 py-1 rounded border border-white/6">deploy</code>
          </div>
        </div>

        <!-- Mobile: vertical stack -->
        <div class="md:hidden space-y-3 animate-fade-up stagger-2">
          <div class="flex items-center gap-3 bg-[#131313] border border-white/6 rounded-lg p-3">
            <span class="flex items-center justify-center w-6 h-6 rounded-full bg-accent-500 text-white text-xs font-mono font-bold shrink-0">1</span>
            <div>
              <span class="text-xs font-semibold text-[#c4c4c0]">{t(strings.quickStartInstall)}</span>
              <code class="block text-[10px] font-mono text-accent-300 mt-0.5">bun add tyndale tyndale-react</code>
            </div>
          </div>
          <div class="flex items-center gap-3 bg-[#131313] border border-white/6 rounded-lg p-3">
            <span class="flex items-center justify-center w-6 h-6 rounded-full bg-accent-500 text-white text-xs font-mono font-bold shrink-0">2</span>
            <div>
              <span class="text-xs font-semibold text-[#c4c4c0]">{t(strings.quickStartInit)}</span>
