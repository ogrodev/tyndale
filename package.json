{
  "name": "tyndale",
  "description": "AI-powered i18n for React and Next.js",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ogrodev/tyndale.git"
  },
  "homepage": "https://tyndale.dev",
  "bugs": {
    "url": "https://github.com/ogrodev/tyndale/issues"
  },
  "workspaces": [
    "packages/*",
    "apps/*",
    "tests/e2e/fixture"
  ],
  "scripts": {
    "test": "bun test --cwd packages/tyndale-react && bun test --cwd packages/tyndale-next && bun test --cwd packages/tyndale --isolate && bun test tests/e2e/",
    "test:e2e": "bun test tests/e2e/",
    "test:playwright": "playwright test --config tests/playwright/playwright.config.ts",
    "test:react": "bun test --cwd packages/tyndale-react",
    "test:next": "bun test --cwd packages/tyndale-next",
    "test:cli": "bun test --cwd packages/tyndale --isolate",
    "typecheck": "tsc --build",
    "dev": "bun --cwd apps/website dev",
    "build:website": "bun --cwd apps/website build",
    "build:packages": "bun run --cwd packages/tyndale-react build && bun run --cwd packages/tyndale-next build && bun run --cwd packages/tyndale build"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^6.0.3"
  }
}
